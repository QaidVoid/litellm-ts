{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "name": "@qaidvoid/litellm",
  "version": "1.0.0",
  "exports": "./mod.ts",
  "license": "MIT",
  "tasks": {
    "fmt": "deno fmt",
    "lint": "deno lint",
    "typecheck": "deno check .",
    "test": "deno test src/ scripts/",
    "test:e2e": "deno test --allow-net --allow-env tests/e2e/",
    "check": "deno fmt && deno lint && deno check . && deno test src/ scripts/ && deno run --allow-read scripts/check-routes.ts",
    "check:routes": "deno run --allow-read scripts/check-routes.ts",
    "gen:models": "deno run --allow-read --allow-write --allow-env --allow-net scripts/generate-models.ts",
    "snapshot:routes": "deno run --allow-read --allow-env --allow-write scripts/snapshot-routes.ts",
    "build:npm": "deno run --allow-read --allow-write --allow-env --allow-net --allow-run scripts/build-npm.ts"
  },
  "exclude": [
    "npm/"
  ],
  "imports": {
    "@deno/dnt": "jsr:@deno/dnt@^0.41.3",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.19"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "useTabs": false,
    "singleQuote": false,
    "semiColons": true,
    "proseWrap": "preserve"
  },
  "lint": {
    "exclude": [
      "examples/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "no-console",
        "no-eval",
        "no-external-import",
        "no-self-compare",
        "no-sync-fn-in-async-fn",
        "no-throw-literal",
        "no-useless-rename",
        "single-var-declarator",
        "verbatim-module-syntax"
      ]
    }
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
